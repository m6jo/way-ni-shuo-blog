---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';
import JsonLd from '../components/JsonLd.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TableOfContents from '../components/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	headings: { depth: number; slug: string; text: string }[];
	slug: string;
};

const { title, description, pubDate, updatedDate, heroImage, category, tags, headings = [], slug } = Astro.props;
const hasToc = headings.filter((h) => h.depth <= 3).length > 0;
---

<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} />
		<JsonLd title={title} description={description} pubDate={pubDate} updatedDate={updatedDate} url={Astro.url.href} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}

			/* Article + sidebar layout */
			.article-layout {
				max-width: 100%;
				margin: 0 auto;
			}

			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}

			/* Sidebar: hidden on mobile */
			.toc-sidebar {
				display: none;
			}

			/* Desktop: fixed ToC to the right of prose */
			@media (min-width: 1100px) {
				.toc-sidebar {
					display: block;
					position: fixed;
					right: max(2em, calc((100vw - 720px) / 2 - 240px));
					top: 5em;
					width: 200px;
					max-height: calc(100vh - 6em);
					overflow-y: auto;
				}
				.toc-mobile {
					display: none;
				}
			}

			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.meta {
				display: flex;
				gap: 0.5em;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 0.75em;
			}
			.category-badge {
				background: var(--accent);
				color: #fff;
				padding: 0.15em 0.6em;
				border-radius: 4px;
				font-size: 0.8em;
				text-decoration: none;
			}
			.category-badge:hover {
				opacity: 0.85;
				color: #fff;
			}
			.tag {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				padding: 0.15em 0.6em;
				border-radius: 4px;
				font-size: 0.8em;
				text-decoration: none;
			}
			.tag:hover {
				background: var(--accent);
				color: #fff;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="article-layout">
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
							<div class="meta">
								{category && <a class="category-badge" href={`/category/${category}/`}>{category}</a>}
								{tags && tags.map((tag: string) => (
									<a class="tag" href={`/tag/${tag}/`}>#{tag}</a>
								))}
							</div>
							<hr />
						</div>
						{/* Mobile inline ToC */}
						<div class="toc-mobile">
							<TableOfContents headings={headings} class="toc-inline" />
						</div>
						<slot />
						<ShareButtons title={title} url={Astro.url.href} />
						<RelatedPosts currentSlug={slug} currentTags={tags || []} currentCategory={category} />
						<Giscus />
					</div>
					{/* Desktop sidebar ToC */}
					{hasToc && (
						<aside class="toc-sidebar">
							<div class="toc-sidebar-inner">
								<TableOfContents headings={headings} class="toc-sidebar" />
							</div>
						</aside>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
