---
interface Props {
	headings: { depth: number; slug: string; text: string }[];
	class?: string;
}

const { headings = [], class: className } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth <= 3);
---

{filteredHeadings.length > 0 && (
	<nav class:list={["toc", className]}>
		<div class="toc-title">目錄</div>
		<ul>
			{filteredHeadings.map((heading) => (
				<li class={`toc-depth-${heading.depth}`}>
					<a href={`#${heading.slug}`} data-heading={heading.slug}>{heading.text}</a>
				</li>
			))}
		</ul>
	</nav>
)}

<style>
	.toc {
		font-size: 0.85em;
	}
	.toc-title {
		font-weight: 700;
		font-size: 1.05em;
		margin-bottom: 0.6em;
		color: rgb(var(--gray-dark));
	}
	.toc ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.toc li {
		margin: 0.25em 0;
		line-height: 1.4;
	}
	.toc a {
		text-decoration: none;
		color: rgb(var(--gray));
		transition: color 0.2s;
		display: block;
		padding: 0.1em 0;
		border-left: 2px solid transparent;
		padding-left: 0.8em;
	}
	.toc a:hover {
		color: var(--accent);
	}
	.toc a.active {
		color: var(--accent);
		border-left-color: var(--accent);
		font-weight: 600;
	}
	.toc-depth-2 {}
	.toc-depth-3 {
		padding-left: 1em;
	}
	.toc-depth-3 a {
		font-size: 0.92em;
	}

	/* Inline variant for mobile */
	.toc.toc-inline {
		background: rgb(var(--gray-light));
		border-radius: 8px;
		padding: 1em 1.5em;
		margin-bottom: 2em;
	}
	.toc.toc-inline a {
		border-left: none;
		padding-left: 0;
	}
	.toc.toc-inline .toc-depth-3 {
		padding-left: 1.2em;
	}
</style>

<script>
	function initTocHighlight() {
		const tocLinks = document.querySelectorAll('aside.toc-sidebar a[data-heading]');
		if (!tocLinks.length) return;

		const headingEls = Array.from(tocLinks).map(link => {
			const slug = link.getAttribute('data-heading');
			return slug ? document.getElementById(slug) : null;
		}).filter(Boolean) as HTMLElement[];

		if (!headingEls.length) return;

		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						tocLinks.forEach(l => l.classList.remove('active'));
						const active = document.querySelector(
							`aside.toc-sidebar a[data-heading="${entry.target.id}"]`
						);
						active?.classList.add('active');
					}
				}
			},
			{ rootMargin: '0px 0px -70% 0px', threshold: 0 }
		);

		headingEls.forEach(el => observer.observe(el));
	}

	initTocHighlight();
	document.addEventListener('astro:after-swap', initTocHighlight);
</script>
