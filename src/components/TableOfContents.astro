---
interface Props {
	headings: { depth: number; slug: string; text: string }[];
}

const { headings = [] } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth <= 3);
---

{filteredHeadings.length > 0 && (
	<nav class="toc">
		<details open>
			<summary>目錄</summary>
			<ul>
				{filteredHeadings.map((heading) => (
					<li class={`toc-depth-${heading.depth}`}>
						<a href={`#${heading.slug}`}>{heading.text}</a>
					</li>
				))}
			</ul>
		</details>
	</nav>
)}

<style>
	.toc {
		background: rgb(var(--gray-light));
		border-radius: 8px;
		padding: 1em 1.5em;
		margin-bottom: 2em;
	}
	.toc summary {
		font-weight: 700;
		cursor: pointer;
		font-size: 1.1em;
	}
	.toc ul {
		list-style: none;
		padding: 0;
		margin: 0.5em 0 0 0;
	}
	.toc li {
		margin: 0.3em 0;
		line-height: 1.4;
	}
	.toc a {
		text-decoration: none;
		color: rgb(var(--gray-dark));
	}
	.toc a:hover {
		color: var(--accent);
	}
	.toc-depth-2 {
		padding-left: 0;
	}
	.toc-depth-3 {
		padding-left: 1.2em;
		font-size: 0.9em;
	}
</style>
